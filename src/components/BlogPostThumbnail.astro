---
const { url, title, pubDate, description, draft } = Astro.props;
const isDev = import.meta.env.DEV;
---

<a href={url}>
  <div class="flex flex-col py-5 mt-auto border-b-2 border-gray-100 group">
    <div class="flex items-center gap-2">
      <h3
        class="text-lg font-bold transition duration-300 ease-in-out text-zinc-900 group-hover:text-cyan-600"
      >
        {title}
      </h3>
      {isDev && draft && (
        <span class="text-xs font-sans font-semibold px-2 py-0.5 rounded-full bg-amber-100 text-amber-700 border border-amber-300 shrink-0">
          Draft
        </span>
      )}
    </div>
    <p class="font-serif font-light line-clamp-2">{description}</p>
    <a
      class="font-serif italic text-pink-600 transition-all duration-300 ease-in-out group"
      href={url}
    >
      <span
        class="bg-left-bottom bg-gradient-to-r from-pink-600 to-pink-600 bg-[length:0%_2px] bg-no-repeat group-hover:bg-[length:100%_2px] transition-all duration-500 ease-out"
      >
        Read Full Post
      </span>
    </a>
    <p class="text-sm text-gray-500 font-extralight">{pubDate}</p>
  </div>
</a>
