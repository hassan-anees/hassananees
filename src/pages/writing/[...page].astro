---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import BlogPostThumbnail from "../../components/BlogPostThumbnail.astro";

export async function getStaticPaths({ paginate }) {
  const allPosts = (await getCollection("posts"))
    .filter((post) => (import.meta.env.PROD ? post.data.draft !== true : true))
    .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

  return paginate(allPosts, { pageSize: 5 });
}

const { page } = Astro.props;
---

<Layout title="Writing | Hassan Anees">
  <div class="max-w-screen-sm p-6 font-sans md:mx-auto py-14">
    <h1 class="text-2xl font-bold">Piecing Thoughtful Insights</h1>
    <h1>Deep dives on books, technology, and human behavior.</h1>
    <p>A haven where I exercise writing. Currently a WIP</p>
    <div class="">
      {
        page.data.map((post) => (
          <BlogPostThumbnail
            url={`/posts/${post.id}`}
            title={post.data.title}
            pubDate={post.data.pubDate.toLocaleDateString("en-US", {
              timeZone: "UTC",
              month: "long",
              day: "2-digit",
              year: "numeric",
            })}
            description={post.data.description}
            draft={post.data.draft}
          />
        ))
      }
    </div>

    {
      page.lastPage > 1 && (
        <div class="grid grid-cols-3 items-center mt-10">
          {page.url.prev ? (
            <a
              href={page.url.prev}
              class="text-sm font-sans text-zinc-600 hover:text-cyan-600 transition-colors duration-200"
            >
              ← Previous
            </a>
          ) : (
            <span />
          )}
          <span class="text-sm text-gray-400 font-extralight text-center">
            Page {page.currentPage} of {page.lastPage}
          </span>
          {page.url.next ? (
            <a
              href={page.url.next}
              class="text-sm font-sans text-zinc-600 hover:text-cyan-600 transition-colors duration-200 text-right"
            >
              Next →
            </a>
          ) : (
            <span />
          )}
        </div>
      )
    }
  </div>
</Layout>
