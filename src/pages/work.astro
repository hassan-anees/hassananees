---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const allWork = await getCollection("work");
const industry = allWork.filter((item) => item.data.category === "industry");
const research = allWork.filter((item) => item.data.category === "research");
---

<Layout title="Work | Hassan Anees">
  <div id="work" class="max-w-screen-md md:mx-auto">
    <div class="p-6 py-14">
      <h2 class="text-2xl font-bold">Work</h2>
      <p class="mt-2 mb-4">
        Throughout my studies I had opportunities to engage with a variety of research areas and
        work across numerous industries.
      </p>

      <div class="text-gray-600">
        <div id="industry" class="mb-10">
          <h4 class="text-xl font-bold text-black">Industry</h4>
          {industry.map((item, i) => (
            <div class={i < industry.length - 1 ? "border-b-2 border-gray-100" : ""}>
              <div class="my-4">
                <h2 class="text-lg font-semibold">{item.data.title}</h2>
                <h3 class="font-semibold text-gray-400">{item.data.organization}, {item.data.period}</h3>
              </div>
            </div>
          ))}
        </div>

        <div id="research">
          <h4 class="text-xl font-bold text-black">Research</h4>
          {research.map((item, i) => (
            <div class={i < research.length - 1 ? "border-b-2 border-gray-100" : ""}>
              <div class="my-4">
                <h2 class="text-lg font-semibold">{item.data.title}</h2>
                <h3 class="font-semibold text-gray-400">{item.data.organization}, {item.data.period}</h3>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</Layout>
